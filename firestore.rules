rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isBootstrapAdmin() {
      return signedIn() && request.auth.token.email in [
        "auxiliar.ti@fvadvocacia.com.br"
      ];
    }

    function isConfigAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/config/app)
        && request.auth.token.email in get(/databases/$(database)/documents/config/app).data.adminEmails;
    }

    function isAdmin() {
      return isBootstrapAdmin() || isConfigAdmin();
    }

    match /config/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /counters/{docId} {
      allow read, write: if signedIn();
    }

    match /chamados/{id} {
      allow create: if signedIn();
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
